{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "FastAPI (debug)",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "cwd": "${workspaceFolder}",
            "args": [
                "app.main:app",
                "--host",
                "0.0.0.0",
                "--port",
                "8080",
                "--log-level",
                "debug"
            ],
            "jinja": true,
            "justMyCode": false
        },
        {
            "name": "FastAPI (reload)",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "cwd": "${workspaceFolder}",
            "args": [
                "app.main:app",
                "--reload",
                "--host",
                "0.0.0.0",
                "--port",
                "8080",
                "--log-level",
                "debug"
            ],
            "jinja": true,
            "justMyCode": false,
            "subProcess": true
        }
    ]
}
